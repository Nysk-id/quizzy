{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["role", "nim"]
    },
    "nim_index": {
      ".read": true,
      ".write": "auth != null"
    },
    "events": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["createdBy", "status"]
    },
    "rooms": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["eventId", "status", "code"]
    },
    "questions": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["createdBy", "eventId"]
    },
    "results": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "result_hashes": {
      ".read": true,
      ".write": "auth != null"
    },
    "room_codes": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["code"]
    },
    "settings": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "admin_invites": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["token", "email"]
    }
  }
}
